# Copy this file to .env.local and fill in real values (never commit .env.local).
# See SETUP.md for where each value comes from.

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Write-access token, used by the embedded Studio at /studio.
SANITY_API_TOKEN=

# Shared secret between the Sanity webhook and /api/revalidate.
SANITY_REVALIDATE_SECRET=
