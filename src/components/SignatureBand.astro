---
import { getEntry } from 'astro:content';

const settingsEntry = await getEntry('settings', 'site');
const settings = settingsEntry.data;
const mode = settings.siteMode;
const content = settings[mode];
---

<section id="about" class="section wrap" style="border-bottom: none; padding-bottom: 0;">
  <div class="signature-band radius-lg">
    <svg class="band-graph" viewBox="0 0 1120 600" preserveAspectRatio="xMidYMid slice" role="img" aria-label="Node-graph signature visual">
      <defs>
        <pattern id="band-dot-grid" width="44" height="44" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" fill="var(--band-line)" opacity="0.5" />
        </pattern>
      </defs>
      <rect width="1120" height="600" fill="url(#band-dot-grid)" />

      <!-- Faint secondary cross-links -->
      <g stroke="var(--band-line)" stroke-width="1.5" stroke-linecap="round" opacity="0.7">
        <line x1="680" y1="200" x2="900" y2="270" />
        <line x1="470" y1="120" x2="760" y2="430" />
        <line x1="820" y1="140" x2="1030" y2="380" />
      </g>

      <!-- Primary backbone + hub-to-satellite connections -->
      <g stroke="var(--band-node)" stroke-width="2.2" stroke-linecap="round" opacity="0.85">
        <line x1="680" y1="200" x2="470" y2="120" />
        <line x1="470" y1="120" x2="900" y2="270" />
        <line x1="900" y1="270" x2="760" y2="430" />
        <line x1="760" y1="430" x2="680" y2="200" />

        <line x1="470" y1="120" x2="370" y2="60" />
        <line x1="470" y1="120" x2="620" y2="70" />
        <line x1="470" y1="120" x2="580" y2="200" />

        <line x1="900" y1="270" x2="1000" y2="180" />
        <line x1="900" y1="270" x2="1030" y2="380" />
        <line x1="900" y1="270" x2="820" y2="140" />

        <line x1="760" y1="430" x2="860" y2="510" />
        <line x1="680" y1="200" x2="770" y2="130" />
      </g>

      <!-- Nodes -->
      <g fill="var(--band-node)" opacity="0.95">
        <circle cx="680" cy="200" r="15" />
        <circle cx="470" cy="120" r="13" />
        <circle cx="900" cy="270" r="18" />
        <circle cx="760" cy="430" r="10" />

        <circle cx="370" cy="60" r="5" />
        <circle cx="620" cy="70" r="6" />
        <circle cx="580" cy="200" r="5" />

        <circle cx="1000" cy="180" r="6" />
        <circle cx="1030" cy="380" r="7" />
        <circle cx="820" cy="140" r="5" />

        <circle cx="860" cy="510" r="6" />
        <circle cx="770" cy="130" r="5" />
      </g>
    </svg>
    <div class="band-scrim"></div>

    <div class="band-content">
      <div class="band-kicker">
        <span class="rule"></span>
        <span>{content.heroKicker}</span>
      </div>
      <h1>{content.heroTitle}</h1>
      <p class="hero-description">{content.heroDescription}</p>
      <div class="band-actions">
        <a href={content.ctaHref} class="btn-primary-badge">
          <span class="label">{content.ctaLabel}</span>
          <span class="badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17 17 7M7 7h10v10" />
            </svg>
          </span>
        </a>
        <a href={content.secondaryCtaHref} class="btn-secondary-outline">
          {content.secondaryCtaLabel}
        </a>
      </div>
      <div class="band-proof">
        <div class="num">7 Years</div>
        <div class="cap">Machine learning, forecasting, and AI systems across regulatory, corporate, and digital sectors</div>
      </div>
    </div>
  </div>
</section>
