---
interface Props {
  items: Array<{ q: string; a: string }>;
}

const { items } = Astro.props;
---

<div class="cs-content" style="gap: var(--brand-size-lg);">
  {items.map((item) => (
    <div class="adr-item">
      <div class="adr-q">Q: {item.q}</div>
      <div class="adr-a" set:html={item.a}></div>
    </div>
  ))}
</div>
