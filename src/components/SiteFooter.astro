---
import { getEntry } from 'astro:content';

const settingsEntry = await getEntry('settings', 'site');
const settings = settingsEntry.data;
const isPersonal = settings.siteMode === 'personal';
---

<footer style="margin-top: 80px; border-top: var(--brand-line-width) solid var(--brand-color-border);">
  <div class="wrap footer-container">
    <div>
      &copy; {new Date().getFullYear()} Azharuddin Kazi. All rights reserved. Deployed using the CodeGraphLabs Brand Specification.
    </div>
    <div style="display: flex; gap: var(--brand-size-lg)">
      <a href="/#about">Overview</a>
      {isPersonal ? (
        <a href="/#timeline">Timeline</a>
      ) : (
        <a href="/#services">Services</a>
      )}
      <a href="/#portfolio">Projects</a>
      <a href="/#blog">Blog</a>
    </div>
  </div>
  <div class="wrap" style="margin-top: var(--brand-size-sm); font-size: var(--brand-font-size-sm); color: var(--brand-color-text-tertiary);">
    {settings.disclaimer}
  </div>
</footer>
